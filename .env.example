# Lead eventi: Make webhook -> NocoDB -> Stripe
# Copia questo file come `.env.local` solo per lo sviluppo locale.
# In produzione inserisci i valori in Vercel -> Settings -> Environment Variables.
# Non usare il prefisso NEXT_PUBLIC_: questi valori devono restare server-side.

MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_API_KEY=

# Genera con: openssl rand -hex 32
LEAD_RATE_LIMIT_SALT=

STRIPE_EVENT_PAYMENT_URL=https://book.stripe.com/test_dRmbJ12KZ8Xm1Sq1R457W00
